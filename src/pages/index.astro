---
import BaseLayout from '../layouts/BaseLayout.astro';
import { useTranslations } from '../i18n/utils';

const lang = 'zh';
const t = useTranslations(lang);
---

<BaseLayout title="黄钰 - 个人主页" description="黄钰的个人学术主页" lang={lang}>
  <!-- Hero -->
  <section class="hero">
    <img
      src="/miku1.jpg"
      alt="黄钰"
      class="hero-avatar"
    />
    <div class="hero-info">
      <h1>黄钰</h1>
      <p class="hero-subtitle">{t('home.subtitle')}</p>
      <p>{t('home.intro')}</p>
      <div class="hero-links">
        <a href="mailto:2418527951@qq.com">Email</a>
        <a href="https://github.com/2418527951h" target="_blank" rel="noopener">GitHub</a>
      </div>
    </div>
  </section>

  <!-- Research Keywords -->
  <section>
    <h2 class="section-title">{t('research.directions')}</h2>
    <div style="display: flex; flex-wrap: wrap; gap: 0.5rem;">
      <span class="tag" style="font-size: 0.9rem; padding: 0.3em 0.8em;">行人重识别 (ReID)</span>
      <span class="tag" style="font-size: 0.9rem; padding: 0.3em 0.8em;">数据集质量评估</span>
      <span class="tag" style="font-size: 0.9rem; padding: 0.3em 0.8em;">多模态学习</span>
      <span class="tag" style="font-size: 0.9rem; padding: 0.3em 0.8em;">计算机视觉</span>
    </div>
  </section>

  <!-- Education -->
  <section>
    <h2 class="section-title">教育经历</h2>
    <ul class="timeline">
      <li class="timeline-item">
        <div class="timeline-date">2025 - 至今</div>
        <strong>北京航空航天大学 · 电子信息</strong>
        <p>硕士研究生，研究方向：计算机视觉</p>
      </li>
      <li class="timeline-item">
        <div class="timeline-date">2021 - 2025</div>
        <strong>北京航空航天大学 · 计算机科学与技术</strong>
        <p>本科</p>
      </li>
    </ul>
  </section>

  <!-- Internship -->
  <section>
    <h2 class="section-title">实习经历</h2>
    <div class="intern-item">
      <div class="intern-header">
        <strong>多模态算法研究员</strong>
        <span class="intern-company">百度健康</span>
      </div>
      <p class="intern-desc">为百度健康业务构建智能医疗相关算法能力，提升健康服务的效率与用户体验。</p>

      <div class="intern-project">
        <div class="intern-project-title">VITA 内部意图识别</div>
        <div class="intern-tech-line">DAPO · SFT · Qwen3.5-0.8B · InternVL3.5-1B · ms-swift</div>
      </div>

      <div class="intern-project">
        <div class="intern-project-title">健康档案 APP</div>
        <div class="intern-tech-line">ResNet-18 · MobileNet-small · ONNX · MNN</div>
      </div>
    </div>
  </section>

  <!-- Skills -->
  <section>
    <h2 class="section-title">技能</h2>
    <ul>
      <li><strong>编程语言:</strong> Python, C/C++, Java</li>
      <li><strong>深度学习:</strong> PyTorch, OpenCV</li>
      <li><strong>工具:</strong> Git, Linux, Docker, LaTeX</li>
    </ul>
  </section>

  <!-- Contact -->
  <section>
    <h2 class="section-title">联系方式</h2>
    <ul style="list-style: none; padding-left: 0;">
      <li>Email: <a href="mailto:2418527951@qq.com">2418527951@qq.com</a></li>
      <li>GitHub: <a href="https://github.com/2418527951h" target="_blank" rel="noopener">github.com/2418527951h</a></li>
    </ul>
  </section>
</BaseLayout>

<style>
  .intern-item {
    margin-bottom: var(--spacing-lg);
  }

  .intern-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: var(--spacing-sm);
    font-size: 1.05rem;
  }

  .intern-company {
    color: var(--color-accent);
    font-weight: 600;
  }

  .intern-desc {
    color: var(--color-text-muted);
    margin-bottom: var(--spacing-lg);
  }

  .intern-project {
    margin-bottom: var(--spacing-lg);
    padding-left: var(--spacing-md);
    border-left: 3px solid var(--color-accent);
  }

  .intern-project-title {
    font-weight: 600;
    margin-bottom: var(--spacing-sm);
  }

  .intern-tech-line {
    font-size: 0.85rem;
    color: var(--color-text-light);
  }
</style>
