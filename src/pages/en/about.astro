---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { useTranslations } from '../../i18n/utils';

const lang = 'en';
const t = useTranslations(lang);
---

<BaseLayout title="About - Yu Huang" description="About Yu Huang" lang={lang}>
  <h1>{t('about.title')}</h1>

  <p>
    Hi! I'm Yu Huang, a researcher in computer vision.
    My research focuses on Person Re-Identification (ReID), dataset quality assessment and optimization,
    and I'm also exploring multimodal learning.
  </p>

  <!-- Education -->
  <h2 class="section-title">{t('about.education')}</h2>
  <ul class="timeline">
    <li class="timeline-item">
      <div class="timeline-date">2025 - Present</div>
      <strong>Beihang University · Electronic Information</strong>
      <p>Master's Student, Research: Computer Vision</p>
    </li>
    <li class="timeline-item">
      <div class="timeline-date">2021 - 2025</div>
      <strong>Beihang University · Computer Science and Technology</strong>
      <p>Bachelor's Degree</p>
    </li>
  </ul>

  <!-- Skills -->
  <h2 class="section-title">{t('about.skills')}</h2>
  <ul>
    <li><strong>Languages:</strong> Python, C/C++, Java</li>
    <li><strong>Deep Learning:</strong> PyTorch, OpenCV</li>
    <li><strong>Tools:</strong> Git, Linux, Docker, LaTeX</li>
  </ul>

  <!-- Contact -->
  <h2 class="section-title">{t('about.contact')}</h2>
  <ul style="list-style: none; padding-left: 0;">
    <li>Email: <a href="mailto:2418527951@qq.com">2418527951@qq.com</a></li>
    <li>GitHub: <a href="https://github.com/2418527951h" target="_blank" rel="noopener">github.com/2418527951h</a></li>
  </ul>
</BaseLayout>
