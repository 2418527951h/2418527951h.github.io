---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { useTranslations } from '../../i18n/utils';

const lang = 'en';
const t = useTranslations(lang);
---

<BaseLayout title="Yu Huang - Homepage" description="Yu Huang's personal academic homepage" lang={lang}>
  <!-- Hero -->
  <section class="hero">
    <img
      src="/miku1.jpg"
      alt="Yu Huang"
      class="hero-avatar"
    />
    <div class="hero-info">
      <h1>Yu Huang</h1>
      <p class="hero-subtitle">{t('home.subtitle')}</p>
      <p>{t('home.intro')}</p>
      <div class="hero-links">
        <a href="mailto:2418527951@qq.com">Email</a>
        <a href="https://github.com/2418527951h" target="_blank" rel="noopener">GitHub</a>
      </div>
    </div>
  </section>

  <!-- Research Keywords -->
  <section>
    <h2 class="section-title">{t('research.directions')}</h2>
    <div style="display: flex; flex-wrap: wrap; gap: 0.5rem;">
      <span class="tag" style="font-size: 0.9rem; padding: 0.3em 0.8em;">Person Re-ID</span>
      <span class="tag" style="font-size: 0.9rem; padding: 0.3em 0.8em;">Dataset Quality</span>
      <span class="tag" style="font-size: 0.9rem; padding: 0.3em 0.8em;">Multimodal Learning</span>
      <span class="tag" style="font-size: 0.9rem; padding: 0.3em 0.8em;">Computer Vision</span>
    </div>
  </section>

  <!-- Education -->
  <section>
    <h2 class="section-title">Education</h2>
    <ul class="timeline">
      <li class="timeline-item">
        <div class="timeline-date">2025 - Present</div>
        <strong>Beihang University · Electronic Information</strong>
        <p>Master's Student, Research: Computer Vision</p>
      </li>
      <li class="timeline-item">
        <div class="timeline-date">2021 - 2025</div>
        <strong>Beihang University · Computer Science and Technology</strong>
        <p>Bachelor's Degree</p>
      </li>
    </ul>
  </section>

  <!-- Internship -->
  <section>
    <h2 class="section-title">Internship</h2>
    <div class="intern-item">
      <div class="intern-header">
        <strong>Multimodal Algorithm Researcher</strong>
        <span class="intern-company">Baidu Health</span>
      </div>
      <p class="intern-desc">Building intelligent medical algorithm capabilities for Baidu's health business to improve service efficiency and user experience.</p>

      <div class="intern-project">
        <div class="intern-project-title">VITA Intent Recognition</div>
        <div class="intern-tech-line">DAPO · SFT · Qwen3.5-0.8B · InternVL3.5-1B · ms-swift</div>
      </div>

      <div class="intern-project">
        <div class="intern-project-title">Health Records APP</div>
        <div class="intern-tech-line">ResNet-18 · MobileNet-small · ONNX · MNN</div>
      </div>
    </div>
  </section>

  <!-- Skills -->
  <section>
    <h2 class="section-title">Skills</h2>
    <ul>
      <li><strong>Languages:</strong> Python, C/C++, Java</li>
      <li><strong>Deep Learning:</strong> PyTorch, OpenCV</li>
      <li><strong>Tools:</strong> Git, Linux, Docker, LaTeX</li>
    </ul>
  </section>

  <!-- Contact -->
  <section>
    <h2 class="section-title">Contact</h2>
    <ul style="list-style: none; padding-left: 0;">
      <li>Email: <a href="mailto:2418527951@qq.com">2418527951@qq.com</a></li>
      <li>GitHub: <a href="https://github.com/2418527951h" target="_blank" rel="noopener">github.com/2418527951h</a></li>
    </ul>
  </section>
</BaseLayout>

<style>
  .intern-item {
    margin-bottom: var(--spacing-lg);
  }

  .intern-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: var(--spacing-sm);
    font-size: 1.05rem;
  }

  .intern-company {
    color: var(--color-accent);
    font-weight: 600;
  }

  .intern-desc {
    color: var(--color-text-muted);
    margin-bottom: var(--spacing-lg);
  }

  .intern-project {
    margin-bottom: var(--spacing-lg);
    padding-left: var(--spacing-md);
    border-left: 3px solid var(--color-accent);
  }

  .intern-project-title {
    font-weight: 600;
    margin-bottom: var(--spacing-sm);
  }

  .intern-tech-line {
    font-size: 0.85rem;
    color: var(--color-text-light);
  }
</style>
