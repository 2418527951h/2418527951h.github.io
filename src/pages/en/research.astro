---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { useTranslations } from '../../i18n/utils';

const lang = 'en';
const t = useTranslations(lang);
---

<BaseLayout title="Research - Yu Huang" description="Yu Huang's research" lang={lang}>
  <h1>{t('research.title')}</h1>

  <!-- Research Directions -->
  <h2 class="section-title">{t('research.directions')}</h2>

  <h3>Person Re-Identification (ReID)</h3>
  <p>
    Studying person matching and retrieval across cameras,
    focusing on feature representation learning and cross-domain adaptation.
  </p>

  <h3>Dataset Quality Assessment & Optimization</h3>
  <p>
    Exploring methods to evaluate training dataset quality
    and improve model performance through data-level optimization.
  </p>

  <h3>Multimodal Learning</h3>
  <p>
    Investigating vision-language multimodal fusion and understanding,
    with interests in cross-modal retrieval and multimodal representation learning.
  </p>

  <!-- Publications (hidden for now, uncomment when ready)
  <hr />
  <h2 class="section-title">{t('research.publications')}</h2>
  -->
</BaseLayout>
