---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { useTranslations } from '../../i18n/utils';

const lang = 'zh';
const t = useTranslations(lang);

const projects = [
  {
    title: '个人学术主页',
    description: '基于 Astro 构建的中英双语个人网站，支持 Markdown 笔记、项目展示，部署在 GitHub Pages。',
    tech: ['Astro', 'TypeScript', 'CSS'],
    link: 'https://github.com/2418527951h',
  },
];
---

<BaseLayout title={`${t('projects.title')} - 黄钰`} description="项目" lang={lang}>
  <h1>{t('projects.title')}</h1>

  {projects.map(project => (
    <div class="card project-card">
      <div class="card-title">{project.title}</div>
      <div class="card-summary">{project.description}</div>
      <div style="margin-top: 0.75rem; display: flex; align-items: center; gap: 1rem;">
        <div>
          {project.tech.map(t => <span class="tag">{t}</span>)}
        </div>
        {project.link && (
          <a href={project.link} target="_blank" rel="noopener" style="font-size: 0.85rem;">
            GitHub &rarr;
          </a>
        )}
      </div>
    </div>
  ))}

  <p style="color: var(--color-text-light); font-style: italic; margin-top: 2rem;">
    更多项目持续更新中...
  </p>
</BaseLayout>

<style>
  .project-card {
    transition: transform 0.2s, border-color 0.2s;
  }

  .project-card:hover {
    transform: translateY(-2px);
  }
</style>
