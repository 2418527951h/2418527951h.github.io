---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { useTranslations } from '../../i18n/utils';
import { getCollection } from 'astro:content';

const lang = 'zh';
const t = useTranslations(lang);

const posts = (await getCollection('notes'))
  .filter(post => post.data.lang === 'zh' && !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title={`${t('notes.title')} - 黄钰`} description="论文笔记" lang={lang}>
  <h1>{t('notes.title')}</h1>

  {posts.length === 0 && <p style="color: var(--color-text-light);">暂无笔记。</p>}

  {posts.map(post => (
    <a href={`/notes/${post.id}`} class="card" style="display: block; text-decoration: none; color: inherit;">
      <div class="card-meta">
        {post.data.date.toLocaleDateString('zh-CN')}
        {post.data.paper_venue && <span> · {post.data.paper_venue}</span>}
      </div>
      <div class="card-title">{post.data.title}</div>
      {post.data.summary && <div class="card-summary">{post.data.summary}</div>}
      {post.data.tags.length > 0 && (
        <div style="margin-top: 0.5rem;">
          {post.data.tags.map(tag => <span class="tag">{tag}</span>)}
        </div>
      )}
    </a>
  ))}
</BaseLayout>
